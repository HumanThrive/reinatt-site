---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const showDrafts = !import.meta.env.PROD;

const posts = (await getCollection("writing", ({ data }) => showDrafts || !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const readingMinutes = (body: string) => {
  const words = body.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
};
---

<Layout title="Writing — Rei" description="Posts by Rei Nuttanon — building, operating, and surviving small businesses from a non-Western perspective.">
  <section class="space-y-2">
    <h1 class="text-3xl font-medium tracking-tight">Writing</h1>
  </section>

  {
    posts.length === 0 ? (
      <p class="mt-10 text-(--color-fg-muted)">
        Empty for now. First posts land this week.
      </p>
    ) : (
      <ul class="mt-10 space-y-6">
        {posts.map((post) => (
          <li>
            <a href={`/writing/${post.id}`} class="no-underline group block">
              <div class="flex items-baseline justify-between gap-4">
                <h2 class="font-medium text-lg group-hover:underline underline-offset-2 decoration-(--color-fg)">
                  {post.data.title}
                </h2>
                <time
                  datetime={post.data.date.toISOString()}
                  class="text-sm text-(--color-fg-muted) shrink-0"
                >
                  {dateFmt(post.data.date)}
                </time>
              </div>
              <div class="flex items-baseline gap-3 mt-1 text-sm text-(--color-fg-muted)">
                <span>{readingMinutes(post.body ?? "")} min read</span>
                {post.data.draft && <span class="text-amber-600">draft</span>}
              </div>
              {post.data.excerpt && (
                <p class="text-sm text-(--color-fg-muted) mt-2 leading-relaxed">{post.data.excerpt}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    )
  }
</Layout>
