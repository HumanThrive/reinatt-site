---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const showDrafts = !import.meta.env.PROD;
  const posts = (await getCollection("writing", ({ data }) => showDrafts || !data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );

  return posts.map((post, idx) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[idx + 1] ?? null,
      next: posts[idx - 1] ?? null,
    },
  }));
}

interface Props {
  post: CollectionEntry<"writing">;
  prev: CollectionEntry<"writing"> | null;
  next: CollectionEntry<"writing"> | null;
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const wordCount = (post.body ?? "").split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));

const postUrl = new URL(`/writing/${post.id}`, Astro.site).toString();

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.excerpt ?? "",
  "datePublished": post.data.date.toISOString(),
  "dateModified": (post.data.updatedDate ?? post.data.date).toISOString(),
  "author": {
    "@type": "Person",
    "name": "Rei Nuttanon",
    "alternateName": "Rei",
    "url": "https://reinatt.com",
  },
  "publisher": {
    "@type": "Person",
    "name": "Rei Nuttanon",
    "url": "https://reinatt.com",
  },
  "url": postUrl,
  "mainEntityOfPage": { "@type": "WebPage", "@id": postUrl },
  "inLanguage": "en",
};
---

<Layout
  title={`${post.data.title} — Rei`}
  description={post.data.excerpt}
  type="article"
  jsonLd={blogPostingSchema}
>
  <article class="space-y-6">
    <header class="space-y-3">
      <h1 class="text-3xl font-medium tracking-tight leading-tight">{post.data.title}</h1>
      <div class="flex items-baseline gap-3 text-sm text-(--color-fg-muted)">
        <time datetime={post.data.date.toISOString()}>{dateFmt(post.data.date)}</time>
        <span>·</span>
        <span>{readingMinutes} min read</span>
        {
          post.data.updatedDate && (
            <>
              <span>·</span>
              <span>updated {dateFmt(post.data.updatedDate)}</span>
            </>
          )
        }
        {post.data.draft && <span class="text-amber-600">· draft</span>}
      </div>
    </header>

    <div
      class="prose-content space-y-5 leading-relaxed [&_h2]:text-xl [&_h2]:font-medium [&_h2]:mt-10 [&_h2]:mb-3 [&_h3]:text-lg [&_h3]:font-medium [&_h3]:mt-8 [&_h3]:mb-2 [&_p]:leading-relaxed [&_a]:underline [&_a]:underline-offset-2 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:list-decimal [&_ol]:pl-6 [&_li]:mt-1 [&_blockquote]:border-l-2 [&_blockquote]:border-(--color-rule) [&_blockquote]:pl-4 [&_blockquote]:text-(--color-fg-muted) [&_pre]:bg-stone-100 [&_pre]:p-4 [&_pre]:rounded [&_pre]:overflow-x-auto [&_pre]:text-sm [&_code]:font-mono [&_code]:text-sm [&_:not(pre)>code]:bg-stone-100 [&_:not(pre)>code]:px-1 [&_:not(pre)>code]:py-0.5 [&_:not(pre)>code]:rounded"
    >
      <Content />
    </div>

    {
      (prev || next) && (
        <nav class="mt-12 pt-6 border-t border-(--color-rule) flex justify-between gap-4 text-sm">
          {prev ? (
            <a href={`/writing/${prev.id}`} class="no-underline group max-w-[45%]">
              <div class="text-(--color-fg-muted) text-xs">← Previous</div>
              <div class="group-hover:underline underline-offset-2 decoration-(--color-fg) mt-1">
                {prev.data.title}
              </div>
            </a>
          ) : (
            <span />
          )}
          {next ? (
            <a href={`/writing/${next.id}`} class="no-underline group max-w-[45%] text-right">
              <div class="text-(--color-fg-muted) text-xs">Next →</div>
              <div class="group-hover:underline underline-offset-2 decoration-(--color-fg) mt-1">
                {next.data.title}
              </div>
            </a>
          ) : (
            <span />
          )}
        </nav>
      )
    }
  </article>
</Layout>
