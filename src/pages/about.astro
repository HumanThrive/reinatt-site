---
import Layout from "../layouts/Layout.astro";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Rei Nuttanon",
  "alternateName": "Rei",
  "url": "https://reinatt.com/about",
  "mainEntityOfPage": "https://reinatt.com/about",
  "sameAs": [
    "https://x.com/_reinatt",
    "https://instagram.com/_reinatt",
    "https://github.com/HumanThrive",
  ],
  "jobTitle": "Full-stack developer",
  "description":
    "Thai full-stack developer based in Bangkok. Builder, fighter, creator. Previously ran an idol management company in Vietnam (HCMC) for six years; rebuilding now in Bangkok.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Bangkok",
    "addressCountry": "TH",
  },
  "knowsLanguage": ["en", "th", "vi", "ja"],
  "nationality": { "@type": "Country", "name": "Thailand" },
  "alumniOf": [],
};
---

<Layout
  title="About — Rei"
  description="About Rei Nuttanon — a Thai full-stack dev who ran an idol management company in Vietnam, came back broken, and is rebuilding."
  jsonLd={personSchema}
>
  <article class="space-y-6">
    <header class="space-y-2">
      <h1 class="text-3xl font-medium tracking-tight">About</h1>
    </header>

    <div class="prose-content space-y-5 leading-relaxed text-(--color-fg)">
      <p>
        Hi, I'm Rei Nuttanon. I'm a Thai full-stack developer based in Bangkok. I've been writing
        code since 19; that's been the backbone profession for over a decade.
      </p>

      <p>
        Between 27 and 33, I lived in Ho Chi Minh City and ran an idol management company —
        seven artists, six years, three original tracks composed. The company is closed now. I
        came back to Bangkok rebuilding finances and rebuilding momentum, and this is where I
        write about it honestly.
      </p>

      <p>
        I write here about building, operating, and surviving small businesses from a
        non-Western perspective — at the intersection of tech, entertainment-industry
        operations, and the rebuild story. I also write about other things I care about: film,
        music, photography, design taste, craft. The whole person, not a focused professional bio.
      </p>

      <p class="text-(--color-fg-muted) text-sm">
        Phase 1 placeholder — full first-person bio rewrite lands during content week (May 4–8).
      </p>

      <h2 class="text-xl font-medium mt-10 mb-3">Reach me</h2>
      <ul class="list-disc pl-6 space-y-1">
        <li><a href="mailto:reinuttanon@gmail.com">reinuttanon@gmail.com</a></li>
        <li><a href="https://x.com/_reinatt" target="_blank" rel="me noopener">X — @_reinatt</a></li>
        <li><a href="https://instagram.com/_reinatt" target="_blank" rel="me noopener">Instagram — @_reinatt</a></li>
      </ul>
    </div>
  </article>
</Layout>
