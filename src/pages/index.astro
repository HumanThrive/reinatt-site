---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const showDrafts = !import.meta.env.PROD;

const allWriting = await getCollection("writing", ({ data }) => showDrafts || !data.draft);
const recentWriting = allWriting
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const allWork = await getCollection("work", ({ data }) => showDrafts || !data.draft);
const featuredWork = allWork
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const dateFmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Rei Nuttanon",
  "alternateName": "Rei",
  "url": "https://reinatt.com",
  "sameAs": [
    "https://x.com/_reinatt",
    "https://instagram.com/_reinatt",
    "https://github.com/HumanThrive",
  ],
  "jobTitle": "Full-stack developer",
  "description":
    "Thai full-stack developer based in Bangkok. Builder, fighter, creator. Previously ran an idol management company in Vietnam.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Bangkok",
    "addressCountry": "TH",
  },
  "knowsLanguage": ["en", "th", "vi", "ja"],
  "nationality": { "@type": "Country", "name": "Thailand" },
};
---

<Layout title="Rei" jsonLd={personSchema}>
  <!-- <section class="space-y-4">
    <h1 class="text-3xl font-medium tracking-tight">Rei</h1>
    <p class="text-(--color-fg) leading-relaxed">
      Builder. Fighter. Creator. A Thai full-stack dev who ran an idol management company in Vietnam,
      came back broken, and is rebuilding. Currently in Bangkok.
    </p>
  </section> -->

  {
    recentWriting.length > 0 && (
      <section class="mt-14 space-y-4">
        <div class="flex items-baseline justify-between">
          <h2 class="text-lg font-medium">Writing</h2>
          <a href="/writing" class="text-sm no-underline text-(--color-fg-muted) hover:text-(--color-fg)">
            All →
          </a>
        </div>
        <ul class="space-y-3">
          {recentWriting.map((post) => (
            <li>
              <a href={`/writing/${post.id}`} class="no-underline group block">
                <div class="flex items-baseline justify-between gap-4">
                  <span class="font-medium group-hover:underline underline-offset-2 decoration-(--color-fg)">
                    {post.data.title}
                  </span>
                  <time
                    datetime={post.data.date.toISOString()}
                    class="text-sm text-(--color-fg-muted) shrink-0"
                  >
                    {dateFmt(post.data.date)}
                  </time>
                </div>
                {post.data.excerpt && (
                  <p class="text-sm text-(--color-fg-muted) mt-1 line-clamp-2">{post.data.excerpt}</p>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    featuredWork.length > 0 && (
      <section class="mt-14 space-y-4">
        <div class="flex items-baseline justify-between">
          <h2 class="text-lg font-medium">Selected work</h2>
          <a href="/work" class="text-sm no-underline text-(--color-fg-muted) hover:text-(--color-fg)">
            All →
          </a>
        </div>
        <ul class="space-y-3">
          {featuredWork.map((entry) => (
            <li>
              <a href={`/work/${entry.id}`} class="no-underline group block">
                <div class="flex items-baseline justify-between gap-4">
                  <span class="font-medium group-hover:underline underline-offset-2 decoration-(--color-fg)">
                    {entry.data.title}
                  </span>
                  <span class="text-sm text-(--color-fg-muted) shrink-0">{entry.data.period}</span>
                </div>
                <p class="text-sm text-(--color-fg-muted) mt-1 line-clamp-2">{entry.data.summary}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Layout>
