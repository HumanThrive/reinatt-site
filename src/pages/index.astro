---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Rei">
  <section class="space-y-6">
    <h1 class="text-3xl font-medium tracking-tight">Rei</h1>
    <p class="text-(--color-fg-muted) leading-relaxed">
      Builder. Fighter. Creator. A Thai full-stack dev who ran an idol management company in Vietnam,
      came back broken, and is rebuilding. Currently in Bangkok.
    </p>
    <p class="text-(--color-fg-muted) text-sm">
      Phase 1 scaffold — content arrives this week. Writing, work, and about pages render their
      templates; content seeds populate Mon–Fri.
    </p>
  </section>
</Layout>
